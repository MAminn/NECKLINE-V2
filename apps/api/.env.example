# NECKLINE API — Environment Variables
# Copy to .env for local development
# NEVER commit .env files (Constitution §4.5)

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB
MONGODB_URI=mongodb://dev:devpassword@localhost:27017/neckline?authSource=admin

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Feature flags (release flags)
FEATURE_CHECKOUT_V2=false
CHECKOUT_ENABLED=true

# Idempotency
IDEMPOTENCY_TTL_HOURS=24
FEATURE_FLAG_CACHE_SECONDS=30

# Payment Provider (Phase 5)
PAYMENT_PROVIDER=stub

# Stub Payment Provider (Phase 4)
STUB_PAYMENT_LATENCY_MS=500
STUB_PAYMENT_FAILURE_RATE=0
STUB_PAYMENT_DECLINE_EMAILS=

# Paymob credentials (Phase 5) — fill when ready to test with real provider
# PAYMOB_API_KEY=skl_xxx
# PAYMOB_INTEGRATION_ID=xxx
# PAYMOB_IFRAME_ID=xxx
# PAYMOB_HMAC_SECRET=xxx
# PAYMOB_BASE_URL=https://accept.paymob.com

# Shipping (Phase 4)
SHIPPING_STANDARD_COST=5000
SHIPPING_CURRENCY=EGP

# Auth
JWT_SECRET=change-me-in-production-min-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=10

# Admin seed script (scripts/seedAdmin.js) — set real values in .env, never here
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

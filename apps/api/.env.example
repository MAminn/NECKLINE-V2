# NECKLINE API — Environment Variables
# Copy to .env for local development
# NEVER commit .env files (Constitution §4.5)

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB
MONGODB_URI=mongodb://dev:devpassword@localhost:27017/neckline?authSource=admin

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Feature flags (release flags)
FEATURE_CHECKOUT_V2=false

# Idempotency
IDEMPOTENCY_TTL_HOURS=24
FEATURE_FLAG_CACHE_SECONDS=30
